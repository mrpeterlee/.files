def is_run_recently(filepath:str, project: str) -> bool:
    """Return True if the project has been executed within `MIN_WAIT_BETWEEN_FILE_RUN` seconds.
    """
    global execution_status

    project = str(project)
    now = pd.Timestamp.now()

    if project not in execution_status:
        execution_status[project] = {}

    if "end_time" in execution_status[project]:
        end_time = execution_status[project]["end_time"]
        # print("The last run was executed at: {}, {} seconds from now.".format(end_time, (now - end_time).seconds))
        if now - end_time< pd.Timedelta(seconds=get_min_wait(filepath)):
            print( f"Detected new modification on file ({project}) - next auto-execution will take place in {get_min_wait(filepath) - (now-end_time).seconds:,} seconds. Skipped execution...")
            return True

    # if "end_time" not in execution_status[project]:
    #     # Still running the 1st time
    #     print(f"Detected new modification on project ({project}) but it is still running the 1st time...")
    #     from pprint import pprint
    #     pprint(execution_status)
    #     return False

    return False


def on_modified(event):
    """Run the task if file is modified."""
    global counter
    global execution_status

    filepath = Path(event.src_path).absolute()

    if Path("/lab/paper/ts/lean") in filepath.parents:
        # This is a Strategy for backtesting
        # Obtain the strategy name
        project = get_project_name_from_path(filepath)
    else:
        project = str(filepath.absolute())

    start_time = pd.Timestamp.now()

    if discard_event(filepath=filepath, project=project):
        return

    global execution_status

    if not filepath.is_file():
        return

    # Identify if this is a Strategy for backtesting - if the current folder is a child folder of /lab/paper/ts
    if is_strategy_project(filepath):
        run_backtest(filepath=filepath, project=project)
    elif filepath.suffix in [".py"]:
        execute_py_file(path=filepath)
    elif filepath.name in ["cli"]:
        execute_py_file(path=filepath)
    elif filepath.suffix in [".md"]:
        execute_markdown_file(path=filepath)
    else:
        print(f"A non-monitored file ({event.src_path}) has been modified...")
        return

    print()

    # Launch pytest counter
    counter += 1

    if counter > COUNTER_TRIGGER_PYTEST:
        run_pytest()
        counter = 1

    # Update execution time
    end_time = pd.Timestamp.now()
    text_done = "Execution completed (time elapsed: {duration}). {cnt:,} more runs until pytest.".format(
        duration=end_time - start_time, cnt=COUNTER_TRIGGER_PYTEST - counter + 1
    )
    execution_status[project]["end_time"] = end_time

    # Update the start_time
    execution_status[project]["start_time"] = start_time

    finclab.util.shell.print_centered_text(
        text=text_done,
        fill=None,
    )


def on_moved(event):
