@dataclass
class MainMenu:
    """FSWatch Main Menu -- Files are executed upon changes of files."""

    folder: typing.Union[str, Path] = str(
        Path("/lab/paper").absolute()
    )  # location of filepath to monitor
    exec_file: typing.Optional[
        str
    ] = None  # upon any file changes in the folder, exec only this filepath
    param: typing.Optional[
        str
    ] = None  # Additional parameter, i.e., "build verbose push remote.com"
    cmd: typing.Optional[
        str
    ] = None  # Specify a full command to be executed upon observing any changes

    def execute(self):
        """Main entry point"""
        # Parse Variables
        self.folder = Path(self.folder)
        refresh_screen()
        print(f"Watching folder: {self.folder}")
        global param
        if self.param is not None:
            param = self.param
        global exec_file
        if self.exec_file is not None:
            exec_file = self.exec_file
        global cmd
        if self.cmd is not None:
            cmd = self.cmd

        fswatch(self.folder)


