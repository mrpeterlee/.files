execution_status = {}  # A dict object to store last run times

def get_min_wait(filepath) -> int:
    """Get the minimum wait time between running the same script"""
    if is_strategy_project(filepath):
        return MIN_WAIT_BETWEEN_PROJECT_RUN
    return MIN_WAIT_BETWEEN_FILE_RUN

def discard_event(filepath: typing.Union[str, Path], project:str) -> bool:
    """True to discard events associated with the filepath"""

    # Discard if `backtests` is part of the path
    if "backtests" in str(filepath):
        return True

    # discard temporary file
    if filepath.stem.isnumeric():
        return True

    # discard __pycache__
    if "__pycache__" in str(filepath):
        return True

    # If run recently
    if is_run_recently(filepath=filepath, project=project):
        return True

    return False

def is_strategy_project(path: typing.Union[str, Path]) -> bool:

    # Return True if this is a Strategy for backtesting - if the current folder is a child folder of /lab/paper/ts
    if "/ts/lean" in str(Path(path).absolute()).replace("\\", "/") and path.suffix in [".py"]:
        return True

    return False

def run_pytest():
    """Execute pytest on the current directory"""
    shell_cmd = 'cd (git rev-parse --show-toplevel) && pytest -v -m "not network"'
    os.system(shell_cmd)


def run_backtest(filepath:str, project:str, max_wait=10, show_output=False):
    """Launch backtest on the target file"""
    global execution_status
    finclab.util.shell.print_centered_text(
            text=f"Backtesting strategy --> {project}",
            fill="=",
            extra_space=10,
        )
 
    backtest_output = cmd_backtest(filepath, detach=False, verbose=True)

    if backtest_output is None:
        print(f"The backtest output file cannot be found")
        return

    # wait for 10 seconds until the file shows up
    wait_counter = 0
    while not Path(backtest_output).is_file() and wait_counter < max_wait:
        time.sleep(1)
        wait_counter += 1

    if not Path(backtest_output, "log.txt").is_file():
        print(f"Backtest output file not found: {backtest_output}")

    # Update the end_time
    execution_status[project]["end_time"] = pd.Timestamp.now()

    # Pring location of the backtest output
    finclab.util.shell.print_centered_text(
            text=f"Time elapsed {(execution_status[project]['end_time']-execution_status[project]['end_time']).seconds} seconds. The backtest output available at: {backtest_output}",
        fill="-",
        extra_space=10,
    )
    
    # If show output
    if show_output:
        # Deprecate python module -> use Glow from terminal
        console = Console()
        from finclab.util.chunk import get_chunks

        with open(Path(backtest_output, "log.txt"), encoding="utf-8") as f:
            content = f.readlines()
            chunk_size = shutil.get_terminal_size().lines
            for chunk in get_chunks(data=content, chunk_size=chunk_size):
                markdown = Markdown("\n".join(chunk))
                time.sleep(1)
                console.print(markdown)
    return


def execute_py_file(path: typing.Union[str, Path]):
    """Execute a py file"""


    if cmd is not None:
        # Executing user specified cmd instead
        print("\n\n\n")
        finclab.util.shell.print_centered_text(
            text=f"Begin to execute '{cmd}' ({pd.Timestamp.now().strftime('%Y-%m-%d %H:%m:%S')})",
            fill="-",
            extra_space=5,
        )
        print()
        os.system(cmd)
        return

    if exec_file is not None:
        path = exec_file
        print(path)

    path = Path(path).absolute()

    # if this is a python unit test
    if path.stem.startswith("test_"):
        shell_cmd = f"cd {path.parent} && pytest -v -s -rP {path}"
        os.system(shell_cmd)
        return

    # Other .py files
    param_str = ""
    if param is not None:
        param_str = f" {param}"

    print("\n\n\n")
    finclab.util.shell.print_centered_text(
        text=f"Begin to execute '{str(path)}' ({pd.Timestamp.now().strftime('%Y-%m-%d %H:%m:%S')})",
        fill="-",
        extra_space=5,
    )
    print()
    shell_cmd = f"cd {path.parent} && python {path}{param_str}"
    print(shell_cmd)
    os.system(shell_cmd)


