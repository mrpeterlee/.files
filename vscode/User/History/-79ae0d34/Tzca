    print(f"ok ok ok, someone moved {event.src_path} to {event.dest_path}")


def fswatch(
    path: typing.Union[str, Path] = Path.cwd().absolute(),
):
    """Watch for file system changes.
    Parameters
    ----------
        path: the path of the folder to watch for any file events
        exec: upon any file changes in the folder, exec only this filepath
    """
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s - %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )
    event_handler = FileModifiedEvent(path)

    # Event handler
    patterns = "*"
    ignore_patterns = [
        "*/*.json",
        "*/*@neomake*",
        "*.py.*.py",
        "*__pycache__*",
        "*cli.*",
        "*.sync.*",
    ]
    ignore_directories = True
    case_sensitive = True
    event_handler = PatternMatchingEventHandler(
        patterns, ignore_patterns, ignore_directories, case_sensitive
    )

    # Assign dispatcher
    # event_handler.on_created = on_created
    # event_handler.on_deleted = on_deleted
    event_handler.on_modified = on_modified
    # event_handler.on_moved = on_moved

    # Observer will monitor our filesystem, looking for changes that will be handled by the event handler.
    observer = Observer()
    observer.schedule(event_handler, path, recursive=True)

    # Kick off the process
    observer.start()
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        observer.stop()
        observer.join()
    finally:
        observer.stop()
        observer.join()


