{
  "suggest.noselect": false,
  "suggest.enablePreview": true,
  "suggest.removeDuplicateItems": true,
  "codeLens.enable": true,

  "coc.preferences.rootPatterns": [
    ".git",
    ".vscode"
  ],

  "coc.preferences.useQuickfixForLocations": true,
  "coc.preferences.snippets.enable": true,
  "coc.preferences.formatOnSaveFiletypes": ["python"],
  "diagnostic.displayByAle": true,
  "coc.preferences.floatActions": false,
  "pyright.enable": true,
  "python.analysis.autoImportCompletions": true,
  "python.pythonPath": "/opt/conda/bin/python",
  "python.venvPath": "/opt/conda/envs",
  "python.formatting.provider": "black",
  "python.formatting.blackPath": "/opt/conda/bin/black",
  "python.formatting.blackArgs": ["--line-length=120"],
  "python.linting.enabled": false,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": false,
  "python.linting.lintOnSave": false,
  "python.jediEnabled": false,
  "python.completion.snippetSupport": false,
  "python.condaPath": "conda",
  "python.sortImports.path": "/opt/conda/bin/isort",
  "python.sortImports.args": [
    "--trailing-comma",
    "--force-grid-wrap", "0",
    "--use-parentheses",
    "--force-single-line-imports",
    "--line-width", "120",
    "--multi-line", "3",
    "--float-to-top"
]
}
