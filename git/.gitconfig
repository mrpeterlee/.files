; user {{{
[user]
	email = peter.lee@astrocapital.net
	name = Peter Lee
; }}}
; core {{{
[core]
	editor    = nvim
	pager = diff-so-fancy | less --tabs=4 -RFX
	autocrlf = false
	whitespace = cr-at-eol
	filemode = false
; }}}
; alias {{{
[alias]
	lod       = log --oneline --decorate --all --graph
	lol       = log --graph --pretty=format:'%C(yellow)%h%Creset -%C(red)%d%Creset %s %C(green)(%cr)'
	loa       = log --graph --pretty=format:'%C(yellow)%h%Creset -%C(red)%d%Creset %s %C(green)(%cr) %C(cyan)[%an]'
; }}}
; color {{{
[color]
	branch    = auto
	diff      = auto
	status    = auto
	ui = true
; }}}
; color diff {{{
[color "diff"]
	meta = 11
	frag = magenta bold
	old = red bold
	new = green bold
	commit = yellow bold
	whitespace = red reverse
; }}}
; color status {{{
[color "status"]
	added     = green
	changed   = red
	unmerged  = yellow
	untracked = magenta
; }}}
; color branch {{{
[color "branch"]
	current   = green
	local     = blue
	remote    = magenta
; }}}
[credential]
	helper = cache --timeout 3600
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[diff-so-fancy]
	markEmptyLines = false
[pull]
	rebase = false
# define command which will be used when "nvim" is set as a merge tool
[mergetool "nvim"]
  cmd = nvim -f -c \"Gdiffsplit!\" \"$MERGED\"
# set "nvim" as tool for merging
[merge]
  tool = nvim
# automatically launch merge tool without displaying a prompt
[mergetool]
  prompt = false
[safe]
	directory = /mnt/diskstation-us1/nfs/public/vm/finclab/wiki
	directory = /mnt/diskstation-us1/nfs/public/vm/finclab
[reset]
	quiet = true
